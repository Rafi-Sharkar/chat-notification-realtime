model garageAdminNotification {
    id                          String  @id @default(uuid())
    userId                      String  @unique
    emailNotification           Boolean @default(false)
    customerInquiryNotification Boolean @default(false)
    productApprovalNotification Boolean @default(false)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("garage_admin_notifications")
}
